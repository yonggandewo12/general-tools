{
  "name": "general-tools-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for converting Markdown/HTML to PDF using Puppeteer",
  "type": "module",
  "bin": {
    "general-tools-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "html",
    "pdf",
    "puppeteer",
    "converter"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "puppeteer": "^23.11.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-anchor": "^4.0.4",
    "@types/node": "^22.10.1",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
